# Зависимости — устанавливаются внутри образа
node_modules

# Артефакты сборки — генерируются внутри образа
dist

# Git и инструменты разработки
.git
.gitignore
.claude
.husky
.vscode
.idea

# Локальные env-файлы (не нужны для production-сборки)
